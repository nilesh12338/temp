<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Multiple Timer Demo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .timer-box {
            text-align: center;
            padding: 20px;
            border: 1px solid #dee2e6;
            border-radius: 10px;
            background: #f8f9fa;
            margin-bottom: 15px;
        }

        .timer-value {
            font-size: 2rem;
            font-weight: bold;
            color: #0d6efd;
        }

        .completed {
            color: #198754;
        }
    </style>
</head>
<body>

<div class="container mt-5">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#timerModal">
        Open Popup
    </button>
</div>

<!-- Modal -->
<div class="modal fade" id="timerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Independent Timers</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="timer-box">
                    <h6>1 Minute Timer</h6>
                    <div id="oneMinuteDisplay" class="timer-value">
                        01:00
                    </div>

                    <button class="btn btn-success btn-sm mt-2"
                            onclick="startOneMinuteTimer()">
                        Start
                    </button>

                    <button class="btn btn-danger btn-sm mt-2"
                            onclick="clearOneMinuteTimer()">
                        Stop
                    </button>
                </div>

                <div class="timer-box">
                    <h6>10 Minute Timer</h6>
                    <div id="tenMinuteDisplay" class="timer-value">
                        10:00
                    </div>

                    <button class="btn btn-success btn-sm mt-2"
                            onclick="startTenMinuteTimer()">
                        Start
                    </button>

                    <button class="btn btn-danger btn-sm mt-2"
                            onclick="clearTenMinuteTimer()">
                        Stop
                    </button>
                </div>

            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

let oneMinuteInterval = null;
let tenMinuteInterval = null;

let oneMinuteRemaining = 60;
let tenMinuteRemaining = 600;

function formatTime(seconds) {
    let mins = Math.floor(seconds / 60);
    let secs = seconds % 60;

    return String(mins).padStart(2, '0') +
        ":" +
        String(secs).padStart(2, '0');
}

function updateDisplays() {
    document.getElementById("oneMinuteDisplay").innerHTML =
        formatTime(oneMinuteRemaining);

    document.getElementById("tenMinuteDisplay").innerHTML =
        formatTime(tenMinuteRemaining);
}

/* ----------------------------
   1 Minute Timer
-----------------------------*/
function startOneMinuteTimer() {

    clearOneMinuteTimer();

    oneMinuteRemaining = 60;
    updateDisplays();

    oneMinuteInterval = setInterval(() => {

        oneMinuteRemaining--;

        updateDisplays();

        if (oneMinuteRemaining <= 0) {

            clearOneMinuteTimer();

            document.getElementById("oneMinuteDisplay")
                .innerHTML = "Completed";

            document.getElementById("oneMinuteDisplay")
                .classList.add("completed");
        }

    }, 1000);
}

function clearOneMinuteTimer() {

    if (oneMinuteInterval) {
        clearInterval(oneMinuteInterval);
        oneMinuteInterval = null;
    }
}

/* ----------------------------
   10 Minute Timer
-----------------------------*/
function startTenMinuteTimer() {

    clearTenMinuteTimer();

    tenMinuteRemaining = 600;
    updateDisplays();

    tenMinuteInterval = setInterval(() => {

        tenMinuteRemaining--;

        updateDisplays();

        if (tenMinuteRemaining <= 0) {

            clearTenMinuteTimer();

            document.getElementById("tenMinuteDisplay")
                .innerHTML = "Completed";

            document.getElementById("tenMinuteDisplay")
                .classList.add("completed");
        }

    }, 1000);
}

function clearTenMinuteTimer() {

    if (tenMinuteInterval) {
        clearInterval(tenMinuteInterval);
        tenMinuteInterval = null;
    }
}

/* ----------------------------
   Modal Events
-----------------------------*/
const modal = document.getElementById('timerModal');

modal.addEventListener('shown.bs.modal', function () {

    document.getElementById("oneMinuteDisplay")
        .classList.remove("completed");

    document.getElementById("tenMinuteDisplay")
        .classList.remove("completed");

    startOneMinuteTimer();
    startTenMinuteTimer();
});

modal.addEventListener('hidden.bs.modal', function () {

    clearOneMinuteTimer();
    clearTenMinuteTimer();

    oneMinuteRemaining = 60;
    tenMinuteRemaining = 600;

    updateDisplays();

    document.getElementById("oneMinuteDisplay")
        .classList.remove("completed");

    document.getElementById("tenMinuteDisplay")
        .classList.remove("completed");
});

updateDisplays();

</script>

</body>
</html>
