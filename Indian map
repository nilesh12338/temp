<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>State Scheme Mapping Demo</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f7f7f7;
}

.map-container{
    position:relative;
    height:600px;
    border:1px solid #ddd;
    background:#fff;
}

#indiaMap{
    width:100%;
    height:100%;
}

.state{
    fill:#bcbcbc;
    stroke:#fff;
    stroke-width:2;
}

.active-state{
    fill:#f5b4d0;
}

#lineLayer{
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    pointer-events:none;
}

.scheme-card{
    border:1px solid #ddd;
    border-radius:10px;
    padding:15px;
    margin-bottom:15px;
    background:#fff;
    min-height:100px;
}

.connector{
    stroke:#999;
    stroke-width:2;
    fill:none;
}

</style>
</head>

<body>

<div class="container-fluid mt-3">

    <div class="row">

        <div class="col-md-5">

            <div class="map-container">

                <!-- DEMO SVG -->
                <svg id="indiaMap" viewBox="0 0 400 500">

                    <!-- Dummy states -->

                    <path id="MP"
                          class="state"
                          d="M130 180 L190 180 L190 240 L130 240 Z"/>

                    <path id="TS"
                          class="state"
                          d="M190 250 L240 250 L240 300 L190 300 Z"/>

                    <path id="AP"
                          class="state"
                          d="M220 310 L290 310 L290 390 L220 390 Z"/>

                    <path id="OR"
                          class="state"
                          d="M260 220 L320 220 L320 280 L260 280 Z"/>

                </svg>

                <svg id="lineLayer"></svg>

            </div>

        </div>

        <div class="col-md-7">

            <div id="schemeCards"></div>

        </div>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>

const schemeData = [

{
    stateCode:'TS',
    stateName:'Telangana',
    schemeName:'Rajiv Yuva Vikasam'
},

{
    stateCode:'AP',
    stateName:'Andhra Pradesh',
    schemeName:'Jagananna Thodu'
},

{
    stateCode:'OR',
    stateName:'Odisha',
    schemeName:'SWAYAM'
},

{
    stateCode:'MP',
    stateName:'Madhya Pradesh',
    schemeName:'CM Rural Street Vendor Loan'
}

];

$(function(){

    renderCards();

    setTimeout(function(){

        drawLines();

    },200);

});

function renderCards(){

    let html='';

    schemeData.forEach(function(item,index){

        html += `
        <div class="scheme-card"
             id="card_${item.stateCode}">

            <small class="text-muted">
                ${item.stateName}
            </small>

            <h5>
                ${item.schemeName}
            </h5>

        </div>
        `;

    });

    $('#schemeCards').html(html);

}

function drawLines(){

    $('#lineLayer').empty();

    schemeData.forEach(function(item){

        $('#' + item.stateCode)
            .addClass('active-state');

        createLine(
            item.stateCode,
            'card_' + item.stateCode
        );

    });

}

function createLine(stateId, cardId){

    const state =
        document.getElementById(stateId);

    const card =
        document.getElementById(cardId);

    if(!state || !card)
        return;

    const stateBox =
        state.getBoundingClientRect();

    const cardBox =
        card.getBoundingClientRect();

    const mapBox =
        document.querySelector('.map-container')
        .getBoundingClientRect();

    const x1 =
        stateBox.right - mapBox.left;

    const y1 =
        stateBox.top +
        stateBox.height/2 -
        mapBox.top;

    const x2 =
        mapBox.width + 20;

    const y2 =
        cardBox.top +
        cardBox.height/2 -
        mapBox.top;

    const svg =
        document.getElementById('lineLayer');

    const polyline =
        document.createElementNS(
            "http://www.w3.org/2000/svg",
            "polyline"
        );

    polyline.setAttribute(
        "points",
        `${x1},${y1}
         ${x1+50},${y1}
         ${x1+50},${y2}
         ${x2},${y2}`
    );

    polyline.setAttribute(
        "class",
        "connector"
    );

    svg.appendChild(polyline);

}

</script>

</body>
</html>
