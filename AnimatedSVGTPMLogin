<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Professional Animated SVG Dashboard</title>
<style>
body {
    margin: 0;
    background: linear-gradient(180deg, #f8fbff, #eef4ff);
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    font-family: system-ui, -apple-system, sans-serif;
}

.scene {
    position: relative;
    width: min(95vw, 1200px);
}

svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,.12));
    animation: floatScene 6s ease-in-out infinite;
}

/* Base Scene Floating Effect */
@keyframes floatScene {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(0.5deg); }
}

/* Dashboard Laser Scan Effect */
.scan-line {
    position: absolute;
    top: 75px;
    left: 390px;
    width: 300px;
    height: 3px;
    background: linear-gradient(90deg, transparent, #ff5b5b, transparent);
    animation: scanMove 3s ease-in-out infinite;
    opacity: .9;
}

@keyframes scanMove {
    0%, 100% { transform: translateX(-100px); opacity: 0.2; }
    50% { transform: translateX(100px); opacity: 1; }
}

/* Pie Chart Radar Pulse */
.piePulse {
    position: absolute;
    right: 95px;
    top: 145px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 4px solid rgba(84, 148, 255, 0.6);
    animation: piePulse 3s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;
    pointer-events: none;
}

@keyframes piePulse {
    0% { transform: scale(0.6); opacity: 1; }
    100% { transform: scale(1.9); opacity: 0; }
}

/* Outer Tech Ring Halo Rotation */
.gearHalo {
    position: absolute;
    left: 450px;
    top: 180px;
    width: 250px;
    height: 250px;
    border: 2px dashed rgba(84, 148, 255, 0.4);
    border-radius: 50%;
    animation: rotateClockwise 25s linear infinite;
}

/* Vector Engine Native Rotations */
.svg-gear-main {
    transform-origin: 573px 298px;
    animation: rotateClockwise 20s linear infinite;
}

.svg-gear-sub {
    transform-origin: 417px 144px;
    animation: rotateCounterClockwise 15s linear infinite;
}

@keyframes rotateClockwise {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

@keyframes rotateCounterClockwise {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
}

/* Dynamic Floating Data Particles */
.particle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5494FF;
    animation: floatParticle 4s infinite ease-in-out;
}

@keyframes floatParticle {
    0%, 100% { transform: translateY(0) scale(0.8); opacity: 0.3; }
    50% { transform: translateY(-30px) scale(1.2); opacity: 0.9; }
}

.p1 { left: 180px; top: 120px; animation-duration: 4.5s; }
.p2 { left: 580px; top: 80px; animation-delay: 1s; animation-duration: 3.5s; }
.p3 { left: 880px; top: 110px; animation-delay: 1.5s; animation-duration: 5s; }
.p4 { left: 740px; top: 340px; animation-delay: 2.2s; animation-duration: 4s; }

/* Micro-interactions: UI Data Bars */
.ui-bar-grow {
    transform-origin: bottom;
    animation: barPulse 4s ease-in-out infinite alternate;
}
.ui-bar-grow:nth-child(2) { animation-delay: 0.4s; }
.ui-bar-grow:nth-child(3) { animation-delay: 0.8s; }

@keyframes barPulse {
    0% { transform: scaleY(0.95); }
    100% { transform: scaleY(1.05); }
}

/* Left Character Subtle Breathing/Typing Animation */
.char-left {
    transform-origin: 190px 400px;
    animation: leftBreathing 4s ease-in-out infinite;
}

@keyframes leftBreathing {
    0%, 100% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(1.01) translate(1px, -3px); }
}

/* Right Character Subtle Analysis Animation */
.char-right {
    transform-origin: 820px 380px;
    animation: rightBreathing 4.5s ease-in-out infinite;
}

@keyframes rightBreathing {
    0%, 100% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(0.99) translate(-1px, -2px); }
}

/* Line Graph Nodes Pulse Accent */
.graph-node {
    animation: nodePulse 2s ease-in-out infinite alternate;
}
@keyframes nodePulse {
    0% { filter: drop-shadow(0 0 2px rgba(241,150,144,0.5)); opacity: 0.8; }
    100% { filter: drop-shadow(0 0 8px rgba(241,150,144,1)); opacity: 1; }
}
</style>
</head>
