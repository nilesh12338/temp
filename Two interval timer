<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Bootstrap Timer Popup Demo</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
.timer-box{
    border:1px solid #dee2e6;
    border-radius:10px;
    padding:15px;
    margin-bottom:15px;
    text-align:center;
}

.timer{
    font-size:28px;
    font-weight:bold;
    color:#0d6efd;
}

.completed{
    color:green;
}
</style>
</head>
<body>

<div class="container mt-5">
    <button class="btn btn-primary" id="btnOpenPopup">
        Open Timer Popup
    </button>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

const popupHtml = `
<div class="modal fade" id="timerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Independent Timers</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <div class="timer-box">
                    <h6>1 Minute Timer</h6>

                    <div id="oneMinuteDisplay"
                         class="timer">
                        01:00
                    </div>

                    <button class="btn btn-success btn-sm mt-2"
                            id="btnStart1">
                        Start
                    </button>

                    <button class="btn btn-danger btn-sm mt-2"
                            id="btnStop1">
                        Stop
                    </button>
                </div>

                <div class="timer-box">
                    <h6>10 Minute Timer</h6>

                    <div id="tenMinuteDisplay"
                         class="timer">
                        10:00
                    </div>

                    <button class="btn btn-success btn-sm mt-2"
                            id="btnStart10">
                        Start
                    </button>

                    <button class="btn btn-danger btn-sm mt-2"
                            id="btnStop10">
                        Stop
                    </button>
                </div>

            </div>

        </div>
    </div>
</div>
`;

function formatTime(seconds) {

    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;

    return String(mins).padStart(2, '0')
           + ':'
           + String(secs).padStart(2, '0');
}

/* ----------------------------
   1 Minute Timer
---------------------------- */

function startOneMinuteTimer() {

    const $modal = $('#timerModal');

    clearOneMinuteTimer();

    const expiry = Date.now() + (60 * 1000);

    $modal.data('oneMinuteExpiry', expiry);

    const intervalId = setInterval(function() {

        const remaining = Math.max(
            0,
            Math.floor(
                ($modal.data('oneMinuteExpiry') - Date.now()) / 1000
            )
        );

        $('#oneMinuteDisplay').text(formatTime(remaining));

        if (remaining <= 0) {

            clearOneMinuteTimer();

            $('#oneMinuteDisplay')
                .text('Completed')
                .addClass('completed');
        }

    }, 1000);

    $modal.data('oneMinuteInterval', intervalId);
}

function clearOneMinuteTimer() {

    const $modal = $('#timerModal');

    const intervalId = $modal.data('oneMinuteInterval');

    if (intervalId) {
        clearInterval(intervalId);
        $modal.removeData('oneMinuteInterval');
    }
}

/* ----------------------------
   10 Minute Timer
---------------------------- */

function startTenMinuteTimer() {

    const $modal = $('#timerModal');

    clearTenMinuteTimer();

    const expiry = Date.now() + (10 * 60 * 1000);

    $modal.data('tenMinuteExpiry', expiry);

    const intervalId = setInterval(function() {

        const remaining = Math.max(
            0,
            Math.floor(
                ($modal.data('tenMinuteExpiry') - Date.now()) / 1000
            )
        );

        $('#tenMinuteDisplay').text(formatTime(remaining));

        if (remaining <= 0) {

            clearTenMinuteTimer();

            $('#tenMinuteDisplay')
                .text('Completed')
                .addClass('completed');
        }

    }, 1000);

    $modal.data('tenMinuteInterval', intervalId);

}

function clearTenMinuteTimer() {

    const $modal = $('#timerModal');

    const intervalId = $modal.data('tenMinuteInterval');

    if (intervalId) {
        clearInterval(intervalId);
        $modal.removeData('tenMinuteInterval');
    }
}

/* ----------------------------
   Open Popup
---------------------------- */

$('#btnOpenPopup').on('click', function() {

    if ($('#timerModal').length === 0) {

        $('body').append(popupHtml);

        $(document).on('click', '#btnStart1', startOneMinuteTimer);
        $(document).on('click', '#btnStop1', clearOneMinuteTimer);

        $(document).on('click', '#btnStart10', startTenMinuteTimer);
        $(document).on('click', '#btnStop10', clearTenMinuteTimer);

        $(document).on('hidden.bs.modal', '#timerModal', function() {

            clearOneMinuteTimer();
            clearTenMinuteTimer();

            $(this).remove();
        });
    }

    const modal = new bootstrap.Modal(
        document.getElementById('timerModal')
    );

    modal.show();

    startOneMinuteTimer();
    startTenMinuteTimer();
});

</script>

</body>
</html>
