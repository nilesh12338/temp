<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome Popup</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body{
            background:#f4f6fb;
        }

        .modal-content{
            border:none;
            border-radius:25px;
            overflow:hidden;
        }

        .welcome-container{
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            position:relative;
            background:#fff;
        }

        .confetti{
            position:absolute;
            width:8px;
            height:8px;
            border-radius:2px;
            opacity:.8;
        }

        .confetti:nth-child(1){top:10%;left:15%;background:#4f8ef7;}
        .confetti:nth-child(2){top:18%;right:18%;background:#ff66c4;}
        .confetti:nth-child(3){top:25%;left:25%;background:#ffd43b;}
        .confetti:nth-child(4){top:12%;right:35%;background:#6ee7b7;}
        .confetti:nth-child(5){bottom:22%;left:18%;background:#a78bfa;}
        .confetti:nth-child(6){bottom:18%;right:20%;background:#60a5fa;}
        .confetti:nth-child(7){bottom:30%;left:35%;background:#facc15;}
        .confetti:nth-child(8){top:40%;right:12%;background:#fb7185;}

        .party-icon{
            font-size:65px;
        }

        .badge-new{
            background:#eef4ff;
            color:#2563eb;
            font-size:15px;
            padding:10px 18px;
            border-radius:30px;
            display:inline-block;
            margin-bottom:20px;
        }

        .title{
            font-size:54px;
            font-weight:800;
            line-height:1.2;
        }

        .title span{
            color:#1677ff;
        }

        .subtitle{
            color:#666;
            font-size:22px;
            margin-top:20px;
        }

        .feature{
            padding:25px 15px;
        }

        .feature i{
            font-size:42px;
            margin-bottom:15px;
        }

        .btn-start{
            margin-top:40px;
            padding:14px 35px;
            border-radius:30px;
            font-size:18px;
        }
    </style>
</head>
<body>

<div class="modal fade" id="welcomeModal" tabindex="-1">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">

            <div class="welcome-container">

                <!-- Decorations -->
                <div class="confetti"></div>
                <div class="confetti"></div>
                <div class="confetti"></div>
                <div class="confetti"></div>
                <div class="confetti"></div>
                <div class="confetti"></div>
                <div class="confetti"></div>
                <div class="confetti"></div>

                <div class="container text-center">

                    <div class="party-icon">🎉</div>

                    <div class="badge-new">
                        ✨ New & Improved
                    </div>

                    <h1 class="title">
                        Welcome to the<br>
                        Revamped <span>LLMSLite!</span>
                    </h1>

                    <p class="subtitle">
                        We've redesigned LLMSLite to give you a<br>
                        smarter, faster and better experience.
                    </p>

                    <div class="row justify-content-center mt-5">

                        <div class="col-md-2 col-6 feature">
                            <i class="bi bi-display text-primary"></i>
                            <h5>Modern</h5>
                            <small>UI / UX</small>
                        </div>

                        <div class="col-md-2 col-6 feature">
                            <i class="bi bi-lightning-charge text-success"></i>
                            <h5>Faster</h5>
                            <small>Smoother</small>
                        </div>

                        <div class="col-md-2 col-6 feature">
                            <i class="bi bi-shield-check text-secondary"></i>
                            <h5>Enhanced</h5>
                            <small>Security</small>
                        </div>

                        <div class="col-md-2 col-6 feature">
                            <i class="bi bi-phone text-warning"></i>
                            <h5>Improved</h5>
                            <small>Usability</small>
                        </div>

                    </div>

                    <button class="btn btn-primary btn-start"
                            data-bs-dismiss="modal">
                        Get Started
                    </button>

                </div>

            </div>

        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
window.onload = function () {
    const modal = new bootstrap.Modal(document.getElementById('welcomeModal'), {
        backdrop: 'static',
        keyboard: false
    });
    modal.show();
};
</script>

</body>
</html>
