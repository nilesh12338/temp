<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Marquee Demo</title>

<style>
body{
    font-family: Arial, sans-serif;
    padding:20px;
}

.marquee-container{
    width:100%;
    height:40px;
    border:1px solid #ccc;
    overflow:hidden;
    position:relative;
}

.marquee-text{
    position:absolute;
    top:50%;
    white-space:nowrap;
    transform:translateY(-50%);
    will-change:transform;
}

@keyframes marqueeScroll{
    from{
        transform:translate(var(--start), -50%);
    }
    to{
        transform:translate(var(--end), -50%);
    }
}
</style>
</head>
<body>

<h3>Marquee Alternative</h3>

<div class="marquee-container" id="marqueeContainer">
    <div class="marquee-text" id="marqueeText">
        This is a dynamic marquee text. Hover over me to pause scrolling.
    </div>
</div>

<br>

<button id="changeTextBtn">Change Text</button>

<script>

const container = document.getElementById("marqueeContainer");
const text = document.getElementById("marqueeText");

function startMarquee() {

    const containerWidth = container.clientWidth;
    const textWidth = text.scrollWidth;

    const distance = containerWidth + textWidth;

    // pixels per second
    const speed = 100;

    const duration = distance / speed;

    text.style.setProperty("--start", containerWidth + "px");
    text.style.setProperty("--end", (-textWidth) + "px");

    text.style.animation = "none";

    // force reflow
    void text.offsetWidth;

    text.style.animation =
        `marqueeScroll ${duration}s linear infinite`;

    text.style.animationPlayState = "running";
}

// Pause on hover
container.addEventListener("mouseenter", function(){
    text.style.animationPlayState = "paused";
});

// Resume on mouse leave
container.addEventListener("mouseleave", function(){
    text.style.animationPlayState = "running";
});

// Dynamic text examples
document.getElementById("changeTextBtn").addEventListener("click", function(){

    const samples = [
        "Short Text",
        "This is a medium length scrolling text.",
        "This is a very long dynamic string loaded from server API and the scrolling speed remains exactly the same regardless of how many characters are present in the text."
    ];

    text.textContent =
        samples[Math.floor(Math.random() * samples.length)];

    startMarquee();
});

window.addEventListener("load", startMarquee);
window.addEventListener("resize", startMarquee);

</script>

</body>
</html>
