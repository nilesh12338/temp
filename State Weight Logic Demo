<!DOCTYPE html>
<html>
<head>
    <title>State Weight Logic Demo</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
        }
        table {
            border-collapse: collapse;
            width: 500px;
            margin-bottom: 20px;
        }
        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }
        input[type="text"] {
            width: 80px;
            text-align: center;
        }
        .result-box {
            margin-top: 10px;
            font-weight: bold;
        }
    </style>
</head>
<body>

<h2>State Weight Evaluation</h2>

<table id="stateTable">
    <thead>
        <tr>
            <th>Sr No</th>
            <th>State Code</th>
            <th>State Weight</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td><input type="text" value="MH" readonly></td>
            <td><input type="text" class="weightInput" value="20"></td>
        </tr>
        <tr>
            <td>2</td>
            <td><input type="text" value="GJ" readonly></td>
            <td><input type="text" class="weightInput" value="15"></td>
        </tr>
        <tr>
            <td>3</td>
            <td><input type="text" value="MJ" readonly></td>
            <td><input type="text" class="weightInput" value="25"></td>
        </tr>
    </tbody>
</table>

<h3>Select Option</h3>
<label><input type="radio" name="stateOption" value="a"> A</label>
<label><input type="radio" name="stateOption" value="b"> B</label>
<label><input type="radio" name="stateOption" value="c"> C</label>

<div class="result-box" id="resultText"></div>

<script>
function evaluateStateWeights() {

    const rows = document.querySelectorAll("#stateTable tbody tr");
    let stateMap = {};
    let allUnique = true;

    rows.forEach(row => {
        const stateCode = row.cells[1].querySelector("input").value.trim();
        const weight = parseFloat(
            row.cells[2].querySelector("input").value
        ) || 0;

        if (stateMap[stateCode]) {
            stateMap[stateCode] += weight;
            allUnique = false;
        } else {
            stateMap[stateCode] = weight;
        }
    });

    let valueToCompare = 0;

    if (allUnique) {
        valueToCompare = Object.values(stateMap)
            .reduce((sum, val) => sum + val, 0);
    } else {
        valueToCompare = Math.max(...Object.values(stateMap));
    }

    let selected = "";

    if (valueToCompare > 50) {
        document.querySelector("input[value='c']").checked = true;
        selected = "C";
    } 
    else if (valueToCompare > 30) {
        document.querySelector("input[value='b']").checked = true;
        selected = "B";
    } 
    else {
        document.querySelector("input[value='a']").checked = true;
        selected = "A";
    }

    document.getElementById("resultText").innerText =
        "Compared Value: " + valueToCompare + " → Selected Option: " + selected;
}

// Trigger on weight input change
document.querySelectorAll(".weightInput").forEach(input => {
    input.addEventListener("input", function () {
        evaluateStateWeights();
    });
});

// Run once on load
evaluateStateWeights();
</script>

</body>
</html>
