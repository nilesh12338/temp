<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Digital Products Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="style.css">

</head>

<body>

<div class="bg-pattern"></div>

<div class="container-fluid py-4">

    <!-- Header -->

    <div class="dashboard-header mb-5">

        <div>

            <h2 class="fw-bold mb-2">
                Digital Products
            </h2>

            <p class="text-muted mb-0">
                Enterprise Banking Applications
            </p>

        </div>

        <div>

            <button class="btn btn-primary px-4">
                Dashboard
            </button>

        </div>

    </div>


    <!-- Hero -->

    <div class="hero-section mb-5">

        <div class="row align-items-center">

            <div class="col-lg-7">

                <span class="hero-badge">
                    SBI Enterprise Platform
                </span>

                <h1 class="mt-3">

                    One Portal.<br>

                    Eight Digital Products.

                </h1>

                <p>

                    Access all banking applications from a single dashboard with
                    modern visualization and enterprise-grade experience.

                </p>

            </div>

            <div class="col-lg-5 text-center">

                <img src="svg/dashboard.svg"
                     class="hero-svg"
                     alt="Dashboard">

            </div>

        </div>

    </div>


    <!-- Product Cards -->

    <div class="row g-4">

        <!-- BRE -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card purple">

                <span class="card-number">
                    01
                </span>

                <div class="svg-box">

                    <img src="svg/bre.svg">

                </div>

                <h4>BRE</h4>

                <p>
                    Business Rule Engine
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>


        <!-- CLP -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card blue">

                <span class="card-number">
                    02
                </span>

                <div class="svg-box">

                    <img src="svg/clp.svg">

                </div>

                <h4>CLP</h4>

                <p>
                    Consumer Loan Processing
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>


        <!-- ERFS -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card orange">

                <span class="card-number">
                    03
                </span>

                <div class="svg-box">

                    <img src="svg/erfs.svg">

                </div>

                <h4>ERFS</h4>

                <p>
                    Electronic Request Flow
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>


        <!-- JanSamarth -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card green">

                <span class="card-number">
                    04
                </span>

                <div class="svg-box">

                    <img src="svg/jansamarth.svg">

                </div>

                <h4>JanSamarth</h4>

                <p>
                    Government Portal
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>



        <!-- LLMS -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card cyan">

                <span class="card-number">
                    05
                </span>

                <div class="svg-box">

                    <img src="svg/llms.svg">

                </div>

                <h4>LLMS BRE 2.0</h4>

                <p>
                    Loan Life Cycle Management
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>



        <!-- PABL -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card pink">

                <span class="card-number">
                    06
                </span>

                <div class="svg-box">

                    <img src="svg/pabl.svg">

                </div>

                <h4>PABL</h4>

                <p>
                    Personal & Business Loan
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>



        <!-- PASBL -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card violet">

                <span class="card-number">
                    07
                </span>

                <div class="svg-box">

                    <img src="svg/pasbl.svg">

                </div>

                <h4>PAsBL</h4>

                <p>
                    Priority Sector Loan
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>



        <!-- SBOSS -->

        <div class="col-xl-3 col-md-6">

            <div class="product-card indigo">

                <span class="card-number">
                    08
                </span>

                <div class="svg-box">

                    <img src="svg/sboss.svg">

                </div>

                <h4>SBOSS</h4>

                <p>
                    Banking Operations Support
                </p>

                <button class="btn-open">
                    Open Product →
                </button>

            </div>

        </div>

    </div>

</div>

</body>

</html>
